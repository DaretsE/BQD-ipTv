<?xml version="1.0" encoding="utf-8"?>
<!--
    Приглушённое выделение строки (состояние "delactive" из прототипа):
    когда фокус переведён на кнопку действия строки (звезда/корзина),
    сама строка гасит своё свечение и остаётся только еле заметная плоская
    подложка — без halo-колец и обводки, в отличие от list_focus.xml.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/delactive_bg" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/delactive_bg" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <color android:color="@android:color/transparent" />
    </item>
</selector>
