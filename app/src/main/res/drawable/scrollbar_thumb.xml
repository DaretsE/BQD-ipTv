<?xml version="1.0" encoding="utf-8"?>
<!--
    Ползунок скроллбара для списка каналов — тонкий (6dp), teal-градиент.
    Соответствует стилю ::-webkit-scrollbar-thumb из HTML-прототипа.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="@color/accent2"
        android:endColor="@color/accent_deep"
        android:type="linear" />
    <corners android:radius="3dp" />
    <size android:width="6dp" />
</shape>
