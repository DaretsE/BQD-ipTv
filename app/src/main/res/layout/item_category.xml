<?xml version="1.0" encoding="utf-8"?>
<!--
    Строка левого меню: тематическая иконка + название + счётчик.
    Иконка подбирается автоматически по названию группы (GroupIcons + IconFont).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/catRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:paddingLeft="14dp"
    android:paddingRight="14dp"
    android:minHeight="52dp">

    <TextView
        android:id="@+id/catIcon"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="14dp"
        android:gravity="center"
        android:textColor="@color/accent2"
        android:textSize="22sp"
        android:includeFontPadding="false" />

    <TextView
        android:id="@+id/catName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/text"
        android:textSize="16sp"
        android:textStyle="bold"
        android:singleLine="true"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/catCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:background="@drawable/badge_bg"
        android:textColor="@color/text_dim2"
        android:textSize="13sp"
        android:textStyle="bold" />
</LinearLayout>
