<?xml version="1.0" encoding="utf-8"?>
<!--
    Строка списка каналов.
    Справа у ВЫДЕЛЕННОГО канала показывается квадратная кнопка действия
    (звезда — добавить в избранное, корзина — убрать). Кнопка живёт вне
    подсветки строки: подсветка рисуется селектором списка, а кнопка имеет
    собственный фон и подсвечивается отдельно, когда фокус переведён на неё.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:paddingLeft="12dp"
    android:paddingRight="8dp"
    android:minHeight="60dp">

    <TextView
        android:id="@+id/rowNum"
        android:layout_width="42dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/text_dim3"
        android:textSize="16sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/rowLogo"
        android:layout_width="58dp"
        android:layout_height="42dp"
        android:layout_marginLeft="4dp"
        android:layout_marginRight="12dp"
        android:background="@drawable/logo_bg"
        android:padding="3dp"
        android:scaleType="fitCenter" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/rowName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text"
            android:textSize="17sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/rowNow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_dim2"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/rowStar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="★"
        android:textColor="@color/accent2"
        android:textSize="16sp"
        android:paddingLeft="8dp"
        android:paddingRight="4dp" />

    <!-- квадратная кнопка действия: видна только у выделенного канала -->
    <TextView
        android:id="@+id/rowAction"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:layout_marginLeft="8dp"
        android:gravity="center"
        android:textSize="22sp"
        android:includeFontPadding="false"
        android:visibility="gone" />
</LinearLayout>
